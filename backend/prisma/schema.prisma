generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WorkType {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  unit      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  workLogs  WorkLog[]

  @@map("work_types")
}

model WorkLog {
  id           String   @id @default(uuid()) @db.Uuid
  date         DateTime @db.Date
  workTypeId   String   @map("work_type_id") @db.Uuid
  volume       Decimal  @db.Decimal(12, 2)
  executorName String   @map("executor_name")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  workType     WorkType @relation(fields: [workTypeId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([workTypeId])
  @@map("work_logs")
}
